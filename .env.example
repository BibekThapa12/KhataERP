# KhataERP public browser configuration
# Copy to .env.local for development. Never place service-role, database,
# Stripe secret, OAuth client secret, JWT signing secret, or third-party secret
# keys in any VITE_* variable: Vite embeds these values in the browser bundle.

# Public Supabase project URL (Supabase Dashboard -> Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public Supabase anon/publishable key only. RLS must remain enabled on every
# exposed table. Never use an sb_secret_* or service_role key here.
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Optional public hCaptcha site key, retained for re-enabling CAPTCHA later.
# Never put the hCaptcha secret key in a VITE_* variable.
VITE_HCAPTCHA_SITE_KEY=

# Optional, development-only structured write timing. Do not enable in production.
VITE_WRITE_PERF=false
